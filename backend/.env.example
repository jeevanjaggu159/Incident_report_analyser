# Backend Environment Variables
# Copy this file to backend/.env and fill in your actual values

# ====== REQUIRED ======
# Get your API key from: https://ai.google.dev
GEMINI_API_KEY=your_actual_api_key_here

# ====== DATABASE (if using PostgreSQL) ======
DATABASE_URL=postgresql://incident_user:incident_password@localhost:5432/incident_analyzer_db

# ====== FREE TIER OPTIMIZATION SETTINGS ======
# These settings help you stay within Google Gemini Free Tier quotas
# Defaults are optimized for free tier - only change if you know what you're doing

# Cache Settings (default: 2 hours, 100 max items)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=7200
MAX_CACHE_SIZE=100

# Rate Limiting (default: 3 seconds minimum between API calls)
# This prevents hitting the 15 requests/minute quota
ENABLE_RATE_LIMITING=true
MIN_REQUEST_INTERVAL_SECONDS=3.0

# LLM Settings (optimized defaults for free tier)
# Lower temperature = more deterministic = potentially lower token usage
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800

# Retry Configuration (handles 429 quota errors gracefully)
FREE_TIER_MAX_RETRIES=5
FREE_TIER_INITIAL_RETRY_DELAY=2

# ====== FAISS CONFIGURATION ======
FAISS_INDEX_PATH=./data/faiss_index.bin
FAISS_METADATA_PATH=./data/faiss_metadata.pkl

# ====== APPLICATION CONFIGURATION ======
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ====== LOGGING CONFIGURATION ======
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ====== RAG CONFIGURATION ======
RAG_TOP_K=3
MIN_SIMILARITY_SCORE=0.5
